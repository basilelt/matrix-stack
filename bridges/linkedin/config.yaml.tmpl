# beeper/linkedin-matrix configuration (Python, unmaintained ~2024)
# Python string.Template file — use render-configs.sh to render.
# Variables: MATRIX_DOMAIN, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, BRIDGE_ADMIN_USER
# Login: DM @linkedinbot, send "login" — provide li_at cookie from linkedin.com
# WARNING: beeper/linkedin-matrix is unmaintained; expect breakage on LinkedIn API changes

homeserver:
  address: http://synapse:8008
  domain: ${MATRIX_DOMAIN}
  software: standard
  status_endpoint: null
  message_send_checkpoint_endpoint: null
  async_media: false

appservice:
  address: http://mautrix-linkedin:29339
  hostname: 0.0.0.0
  port: 29339
  max_body_size: 1

  database: "postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_DB}_linkedin?sslmode=disable"
  database_opts:
    min_size: 1
    max_size: 10

  id: linkedin
  bot_username: linkedinbot
  bot_displayname: LinkedIn bridge bot
  bot_avatar: "mxc://maunium.net/YJbTPuDNBjpBTQXkFLMGwPfq"

  ephemeral_events: true
  async_transactions: false

  as_token: ""
  hs_token: ""

bridge:
  username_template: "linkedin_{userid}"
  displayname_template: "{displayname} (LinkedIn)"
  delivery_receipts: false
  send_presence_on_typing: false
  portal_message_buffer: 128
  double_puppet_server_map: {}
  double_puppet_allow_discovery: false
  login_shared_secret_map:
    ${MATRIX_DOMAIN}: ${DOUBLE_PUPPET_SECRET}
  command_prefix: "!li"

  encryption:
    allow: true
    default: true
    require: false
    allow_key_sharing: true

  permissions:
    "${MATRIX_DOMAIN}": user
    "${BRIDGE_ADMIN_USER}": admin
    "@translate-bot:${MATRIX_DOMAIN}": admin

logging:
  version: 1
  formatters:
    colored:
      (): mautrix.util.logging.color.ColorFormatter
      format: "[%(asctime)s] [%(levelname)s@%(name)s] %(message)s"
  handlers:
    console:
      class: logging.StreamHandler
      formatter: colored
  loggers:
    mau:
      level: DEBUG
    aiohttp:
      level: INFO
  root:
    level: INFO
    handlers: [console]
