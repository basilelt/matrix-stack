# mautrix-twitter configuration (Go megabridge v3)
# Python string.Template file — use render-configs.sh to render.
# Variables: MATRIX_DOMAIN, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, BRIDGE_ADMIN_USER, DOUBLE_PUPPET_SECRET
# Login: DM @twitterbot, send "login-cookie auth_token=<value> ct0=<value>"
# Cookies from x.com: DevTools → Application → Cookies → x.com

network:
  proxy: null

bridge:
  command_prefix: "!tw"
  personal_filtering_spaces: true
  relay:
    enabled: false
    admin_only: true

  permissions:
    "${MATRIX_DOMAIN}": user
    "${BRIDGE_ADMIN_USER}": admin
    "@translate-bot:${MATRIX_DOMAIN}": admin

database:
  type: postgres
  uri: "postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_DB}_twitter?sslmode=disable"
  max_open_conns: 5
  max_idle_conns: 1

homeserver:
  address: http://synapse:8008
  domain: ${MATRIX_DOMAIN}
  software: standard
  status_endpoint: null
  message_send_checkpoint_endpoint: null
  async_media: false

appservice:
  address: http://mautrix-twitter:29337
  hostname: 0.0.0.0
  port: 29337
  id: twitter
  bot:
    username: twitterbot
    displayname: Twitter/X bridge bot
    avatar: "mxc://maunium.net/HVHcnusJkQcpVcsJWRdnuMol"
  ephemeral_events: true
  async_transactions: false
  as_token: ""
  hs_token: ""
  username_template: "twitter_{{.}}"

double_puppet:
  servers: {}
  allow_discovery: false
  secrets:
    ${MATRIX_DOMAIN}: ${DOUBLE_PUPPET_SECRET}

encryption:
  allow: true
  default: true
  require: false
  allow_key_sharing: true
  pickle_key: generate

logging:
  min_level: info
  writers:
  - type: stdout
    format: pretty-colored
