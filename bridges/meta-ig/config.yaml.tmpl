# mautrix-meta configuration — Instagram (Go megabridge v3)
# Python string.Template file — use render-configs.sh to render.
# Variables: MATRIX_DOMAIN, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, BRIDGE_ADMIN_USER, DOUBLE_PUPPET_SECRET

network:
  mode: instagram

bridge:
  command_prefix: "!ig"
  personal_filtering_spaces: true
  # Don't kick Matrix users (e.g. translate-bot) who aren't in the remote chat.
  kick_matrix_users: false
  relay:
    enabled: false
    admin_only: true

  permissions:
    "${MATRIX_DOMAIN}": user
    "${BRIDGE_ADMIN_USER}": admin
    "@translate-bot:${MATRIX_DOMAIN}": admin

database:
  type: postgres
  uri: "postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_DB}_metaig?sslmode=disable"
  max_open_conns: 5
  max_idle_conns: 1

homeserver:
  address: http://synapse:8008
  domain: ${MATRIX_DOMAIN}
  software: standard
  status_endpoint: null
  message_send_checkpoint_endpoint: null
  async_media: false

appservice:
  address: http://mautrix-meta-ig:29341
  hostname: 0.0.0.0
  port: 29341
  id: meta-ig
  bot:
    username: instagrambot
    displayname: Instagram bridge bot
    avatar: "mxc://maunium.net/JxjlbZUlCPULPwRkZfrgrugH"
  ephemeral_events: true
  async_transactions: false
  as_token: ""
  hs_token: ""
  username_template: "instagram_{{.}}"

double_puppet:
  servers: {}
  allow_discovery: false
  secrets:
    ${MATRIX_DOMAIN}: ${DOUBLE_PUPPET_SECRET}

encryption:
  allow: true
  default: true
  require: false
  allow_key_sharing: true
  pickle_key: generate

logging:
  min_level: info
  writers:
  - type: stdout
    format: pretty-colored
