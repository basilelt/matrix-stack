# mautrix-meta configuration — Facebook Messenger (Go megabridge)
# Python string.Template file — use render-configs.sh to render.
# Variables: MATRIX_DOMAIN, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, BRIDGE_ADMIN_USER
# Login: DM @messengerbot, follow bridge login flow (cookie-based)
# Note: Meta actively combats automation; cookies expire. Use cookie-refresher sidecar.

homeserver:
  address: http://synapse:8008
  domain: ${MATRIX_DOMAIN}
  software: standard
  status_endpoint: null
  message_send_checkpoint_endpoint: null
  async_media: false

appservice:
  address: http://mautrix-meta-fb:29340
  hostname: 0.0.0.0
  port: 29340
  max_body_size: 1

  database:
    type: postgres
    uri: "postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_DB}_metafb?sslmode=disable"
    max_open_conns: 20
    max_idle_conns: 2
    max_conn_idle_time: null
    max_conn_lifetime: null

  id: meta-fb
  bot_username: messengerbot
  bot_displayname: Messenger bridge bot
  bot_avatar: "mxc://maunium.net/ygtkteZsXnGJLJHRchUwYWak"

  ephemeral_events: true
  async_transactions: false

  as_token: ""
  hs_token: ""

bridge:
  username_template: "messenger_{{.}}"
  displayname_template: "{{.Name}} (Messenger)"
  personal_filtering_spaces: false
  delivery_receipts: false
  send_presence_on_typing: false
  convert_voice_messages: false
  portal_message_buffer: 128
  sync_direct_chats: true
  double_puppet_server_map: {}
  double_puppet_allow_discovery: false
  login_shared_secret_map: {}
  command_prefix: "!fb"

  permissions:
    "${MATRIX_DOMAIN}": user
    "${BRIDGE_ADMIN_USER}": admin
    "@translate-bot:${MATRIX_DOMAIN}": admin

meta:
  mode: facebook
  ig_e2ee: false

logging:
  min_level: info
  writers:
  - type: stdout
    format: pretty-colored

encryption:
  allow: true
  default: true
  require: false
