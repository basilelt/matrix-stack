# mautrix-googlechat configuration (Python)
# Python string.Template file — use render-configs.sh to render.
# Variables: MATRIX_DOMAIN, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, BRIDGE_ADMIN_USER
# Login: DM @googlechatbot, send "login" — follow OAuth link

homeserver:
  address: http://synapse:8008
  domain: ${MATRIX_DOMAIN}
  software: standard
  status_endpoint: null
  message_send_checkpoint_endpoint: null
  async_media: false

appservice:
  address: http://mautrix-googlechat:29338
  hostname: 0.0.0.0
  port: 29338
  max_body_size: 1

  database:
    type: postgres
    uri: "postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_DB}_googlechat?sslmode=disable"
    max_open_conns: 20
    max_idle_conns: 2
    max_conn_idle_time: null
    max_conn_lifetime: null

  id: googlechat
  bot_username: googlechatbot
  bot_displayname: Google Chat bridge bot
  bot_avatar: "mxc://maunium.net/BDORezJKIJMOCaWXNQvtlOvt"

  ephemeral_events: true
  async_transactions: false

  as_token: ""
  hs_token: ""

bridge:
  username_template: "gchat_{userid}"
  displayname_template: "{displayname} (GChat)"
  delivery_receipts: false
  send_presence_on_typing: false
  portal_message_buffer: 128
  double_puppet_server_map: {}
  double_puppet_allow_discovery: false
  login_shared_secret_map: {}
  command_prefix: "!gc"

  permissions:
    "${MATRIX_DOMAIN}": user
    "${BRIDGE_ADMIN_USER}": admin
    "@translate-bot:${MATRIX_DOMAIN}": admin

logging:
  level: INFO
  handlers:
  - type: stdout
    format: colored
