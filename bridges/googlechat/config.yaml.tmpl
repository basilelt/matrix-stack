# mautrix-googlechat configuration (Python bridge)
# Python string.Template file — use render-configs.sh to render.
# Variables: MATRIX_DOMAIN, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, BRIDGE_ADMIN_USER, DOUBLE_PUPPET_SECRET
# Login: DM @googlechatbot, send "login" — follow OAuth link

homeserver:
  address: http://synapse:8008
  domain: ${MATRIX_DOMAIN}
  software: standard
  status_endpoint: null
  message_send_checkpoint_endpoint: null
  async_media: false

appservice:
  address: http://mautrix-googlechat:29338
  hostname: 0.0.0.0
  port: 29338
  max_body_size: 1
  database: "postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_DB}_googlechat?sslmode=disable"
  database_opts:
    min_size: 1
    max_size: 10
  id: googlechat
  bot_username: googlechatbot
  bot_displayname: Google Chat bridge bot
  bot_avatar: "mxc://maunium.net/BDIWAQcbpPGASPUUBuEGWXnQ"
  ephemeral_events: true
  as_token: ""
  hs_token: ""

bridge:
  username_template: "gchat_{userid}"
  displayname_template: "{full_name} (GChat)"
  command_prefix: "!gc"
  initial_chat_sync: 10
  double_puppet_server_map: {}
  double_puppet_allow_discovery: false
  login_shared_secret_map:
    ${MATRIX_DOMAIN}: ${DOUBLE_PUPPET_SECRET}
  encryption:
    allow: true
    default: true
    require: false
    allow_key_sharing: true

  permissions:
    "${MATRIX_DOMAIN}": user
    "${BRIDGE_ADMIN_USER}": admin
    "@translate-bot:${MATRIX_DOMAIN}": admin

logging:
  version: 1
  formatters:
    colored:
      (): mautrix_googlechat.util.ColorFormatter
      format: "[%(asctime)s] [%(levelname)s@%(name)s] %(message)s"
  handlers:
    console:
      class: logging.StreamHandler
      formatter: colored
  loggers:
    mau:
      level: DEBUG
    maugclib:
      level: INFO
    aiohttp:
      level: INFO
  root:
    level: INFO
    handlers: [console]
