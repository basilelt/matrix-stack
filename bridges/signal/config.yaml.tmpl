# mautrix-signal configuration
# Python string.Template file — use render-configs.sh to render.
# Variables: MATRIX_DOMAIN, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, BRIDGE_ADMIN_USER

homeserver:
  address: http://synapse:8008
  domain: ${MATRIX_DOMAIN}
  software: standard
  status_endpoint: null
  message_send_checkpoint_endpoint: null
  async_media: false

appservice:
  address: http://mautrix-signal:29328
  hostname: 0.0.0.0
  port: 29328
  max_body_size: 1

  database:
    type: postgres
    uri: "postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_DB}_signal?sslmode=disable"
    max_open_conns: 20
    max_idle_conns: 2
    max_conn_idle_time: null
    max_conn_lifetime: null

  id: signal
  bot_username: signalbot
  bot_displayname: Signal bridge bot
  bot_avatar: "mxc://maunium.net/wPJgTQbZOtpBFmDNkiNEMDUp"

  ephemeral_events: true
  async_transactions: false

  as_token: ""
  hs_token: ""

bridge:
  # mautrix-signal (Go) uses Go text/template; {{.UUID}} is the Signal user UUID
  username_template: "signal_{{.UUID}}"
  displayname_template: "{{.Name}} (Signal)"
  personal_filtering_spaces: false
  delivery_receipts: false
  send_presence_on_typing: false
  convert_voice_messages: false
  voice_messages_ffmpeg_args: []
  call_start_notices: true
  identity_change_notices: true
  portal_message_buffer: 128
  sync_direct_chat_list: false
  double_puppet_server_map: {}
  double_puppet_allow_discovery: false
  login_shared_secret_map: {}
  command_prefix: "!signal"

  permissions:
    "${MATRIX_DOMAIN}": user
    "${BRIDGE_ADMIN_USER}": admin

logging:
  min_level: info
  writers:
  - type: stdout
    format: pretty-colored
