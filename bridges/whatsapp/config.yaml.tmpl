# mautrix-whatsapp configuration
# Python string.Template file — use render-configs.sh to render.
# Variables: MATRIX_DOMAIN, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, BRIDGE_ADMIN_USER

homeserver:
  address: http://synapse:8008
  domain: ${MATRIX_DOMAIN}
  software: standard
  status_endpoint: null
  message_send_checkpoint_endpoint: null
  async_media: false

appservice:
  address: http://mautrix-whatsapp:29318
  hostname: 0.0.0.0
  port: 29318
  max_body_size: 1

  database:
    type: postgres
    uri: "postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_DB}_whatsapp?sslmode=disable"
    max_open_conns: 20
    max_idle_conns: 2
    max_conn_idle_time: null
    max_conn_lifetime: null

  id: whatsapp
  bot_username: whatsappbot
  bot_displayname: WhatsApp bridge bot
  bot_avatar: "mxc://maunium.net/NeXNQarUbrlYBiPCpprYsRqr"

  ephemeral_events: true
  async_transactions: false

  as_token: ""
  hs_token: ""

bridge:
  # {{.User}} gives the phone-number part of the JID (strips @s.whatsapp.net suffix)
  # so the resulting Matrix localpart stays valid (no @ or . characters)
  username_template: "whatsapp_{{.User}}"
  displayname_template: "{{if .BusinessName}}{{.BusinessName}}{{else}}{{.PushName}}{{end}} (WA)"
  personal_filtering_spaces: false
  delivery_receipts: false
  send_presence_on_typing: false
  convert_voice_messages: false
  voice_messages_ffmpeg_args: []
  call_start_notices: true
  identity_change_notices: false
  portal_message_buffer: 128
  use_whatsapp_retry_store: true
  history_sync:
    backfill: false

  permissions:
    "*": relay
    "${MATRIX_DOMAIN}": user
    "${BRIDGE_ADMIN_USER}": admin
    "@translate-bot:${MATRIX_DOMAIN}": admin

  relay:
    enabled: true
    admin_only: false
    message_formats:
      m.text: "{{ .Sender.Displayname }}: {{ .Message }}"
      m.notice: "{{ .Sender.Displayname }}: {{ .Message }}"
      m.emote: "* {{ .Sender.Displayname }} {{ .Message }}"
      m.file: "{{ .Sender.Displayname }} sent a file"
      m.image: "{{ .Sender.Displayname }} sent an image"
      m.audio: "{{ .Sender.Displayname }} sent an audio file"
      m.video: "{{ .Sender.Displayname }} sent a video"
      m.location: "{{ .Sender.Displayname }} sent a location"

logging:
  min_level: info
  writers:
  - type: stdout
    format: pretty-colored
