##############################################################################
# .env.example — Matrix-as-Beeper stack environment template
#
# Copy this file to .env and fill in the values marked CHANGE_ME.
#
# Generate strong secrets with:
#   openssl rand -hex 32
#
# Architecture:
#   Internet → Cloudflare → cloudflared (LXC) → YOUR_LXC_IP:8080 → Caddy → Synapse
#   TLS is terminated by Cloudflare — no ACME/Let's Encrypt needed inside the LXC.
#
# NOTE: FEDERATION_ENABLED, ALLOW_REGISTRATION, and other custom vars are NOT
# read by the official Synapse Docker image directly. They are consumed by
# render-configs.sh which generates synapse/homeserver.yaml from them.
# Similarly, SYNAPSE_ADMIN_USER/PASSWORD are used by setup.sh to register
# the initial admin account via register_new_matrix_user — not by Synapse itself.
##############################################################################


# ═══════════════════════════════════════════════════
# DOMAIN / NETWORK
# ═══════════════════════════════════════════════════

# The Matrix server name embedded in MXIDs (e.g. @user:matrix.example.com).
# Must match the Synapse server_name config.
MATRIX_DOMAIN=matrix.example.com

# The public URL where the Matrix client API is reachable.
# Same as MATRIX_DOMAIN for a single-domain setup (no .well-known delegation).
PUBLIC_DOMAIN=matrix.example.com

# No PUBLIC_PORT or ACME_EMAIL needed — cloudflared handles TLS on port 443.
# Traffic path: Internet → Cloudflare → cloudflared LXC → YOUR_LXC_IP:8080 → Caddy → Synapse

# Port Caddy listens on inside the LXC (plain HTTP; cloudflared handles TLS).
CADDY_PORT=8080

# Set to false — this is a personal homeserver, federation adds attack surface.
FEDERATION_ENABLED=false

# Keep closed; invite users manually or via the admin API.
ALLOW_REGISTRATION=false


# ═══════════════════════════════════════════════════
# POSTGRES
# ═══════════════════════════════════════════════════

POSTGRES_USER=synapse
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
POSTGRES_DB=synapse


# ═══════════════════════════════════════════════════
# SYNAPSE
# ═══════════════════════════════════════════════════

# Used by setup.sh (register_new_matrix_user) and render-configs.sh.
# Generate with: openssl rand -hex 32
SYNAPSE_REGISTRATION_SHARED_SECRET=CHANGE_ME_LONG_RANDOM

# Initial admin account created by setup.sh on first run.
SYNAPSE_ADMIN_USER=admin
SYNAPSE_ADMIN_PASSWORD=CHANGE_ME


# ═══════════════════════════════════════════════════
# BRIDGES (flip true to enable)
# ═══════════════════════════════════════════════════

ENABLE_BRIDGE_WHATSAPP=true
ENABLE_BRIDGE_TELEGRAM=false
ENABLE_BRIDGE_SIGNAL=true
ENABLE_BRIDGE_DISCORD=false
ENABLE_BRIDGE_SLACK=false
ENABLE_BRIDGE_GMESSAGES=false
ENABLE_BRIDGE_TWITTER=false
ENABLE_BRIDGE_GOOGLECHAT=false
ENABLE_BRIDGE_LINKEDIN=false
ENABLE_BRIDGE_META_FB=false
ENABLE_BRIDGE_META_IG=false

# Matrix ID of the user who can issue bridge admin commands.
# Update this if you change MATRIX_DOMAIN!
BRIDGE_ADMIN_USER=@admin:matrix.example.com

# ─── Telegram (required when ENABLE_BRIDGE_TELEGRAM=true) ───────────────────
# Get these from https://my.telegram.org/apps (register a "personal use" app).
# mautrix-telegram will refuse to start without a valid integer api_id.
TELEGRAM_API_ID=CHANGE_ME_INTEGER
TELEGRAM_API_HASH=CHANGE_ME_HEX


# ═══════════════════════════════════════════════════
# STT BOT (Whisper)
# ═══════════════════════════════════════════════════

ENABLE_STT_BOT=true

# Localpart of the bot's Matrix account (full ID: @stt-bot:matrix.example.com).
STT_BOT_USER_LOCALPART=stt-bot
# Generate with: openssl rand -hex 32
STT_BOT_PASSWORD=CHANGE_ME
STT_BOT_DEVICE_ID=STTBOT01

# Room the bot auto-joins on startup; update after creating the actual room.
STT_BOT_ROOM_ID=!placeholder-dont-exist:matrix.example.com

# Whisper model size: tiny | base | small | medium | large
# "base" balances speed and accuracy on CPU-only LXC hardware.
WHISPER_MODEL=base

# Set to true only if an NVIDIA GPU is passed through to the LXC.
STT_GPU=false

# End-to-end encryption bootstrap for the bot.
E2EE_BOOTSTRAP=false
# Passphrase used to encrypt the bot's E2EE key backup (leave empty to disable).
E2EE_KEYS_PASSWORD=

# Shared secret used as the as_token for the doublepuppet appservice.
# setup.sh uses this to create synapse/appservices/doublepuppet-registration.yaml and wire
# double_puppet.secrets in every bridge config so bridges can impersonate your Matrix user.
# Generate with: openssl rand -hex 32
DOUBLE_PUPPET_SECRET=


# ═══════════════════════════════════════════════════
# AUTO-UPDATES
# ═══════════════════════════════════════════════════

# Watchtower polling interval in seconds (86400 = 24 h).
WATCHTOWER_INTERVAL=86400
# Remove old images after updating containers.
WATCHTOWER_CLEANUP=true
# Optional: Shoutrrr-format URL for update notifications (leave empty to disable).
# Example: slack://token@channel or generic+https://hooks.example.com/...
WATCHTOWER_NOTIFICATION_URL=

# Set to true to enable automatic OS package updates inside the LXC.
INSTALL_OS_AUTOUPDATE=true


# ═══════════════════════════════════════════════════
# MISC
# ═══════════════════════════════════════════════════

TZ=Europe/Paris

# Your primary Matrix username (used by translate-bot to invite you into bridge rooms).
MATRIX_USER=yourusername


# ═══════════════════════════════════════════════════
# COOKIE REFRESHER (auto re-login for cookie bridges)
# ═══════════════════════════════════════════════════

# Set true after manually verifying at least one cookie bridge works.
ENABLE_COOKIE_REFRESHER=false

# Matrix user the refresher logs in as (created by setup.sh).
COOKIE_REFRESHER_PASSWORD=CHANGE_ME_LONG_RANDOM

# Fernet key to encrypt stored credentials — openssl rand -base64 32
# KEEP THIS SECRET. Losing it means re-seeding all bridge credentials.
COOKIE_REFRESHER_KEY=CHANGE_ME_BASE64_32


# ═══════════════════════════════════════════════════
# TRANSLATE BOT (LibreTranslate + Whisper on-demand)
# ═══════════════════════════════════════════════════

# Set to true to enable the translate + transcribe bot.
ENABLE_TRANSLATE_BOT=false

# Claude Code session notification bot (webhook relay → encrypted DM to MATRIX_USER).
ENABLE_CLAUDE_NOTIFY=false
CLAUDE_NOTIFY_USER_LOCALPART=claude-notify
CLAUDE_NOTIFY_PASSWORD=CHANGE_ME_LONG_RANDOM
# openssl rand -hex 32
CLAUDE_NOTIFY_WEBHOOK_TOKEN=CHANGE_ME_LONG_RANDOM

# Matrix user the bot will log in as (created by setup.sh).
TRANSLATE_BOT_USER_LOCALPART=translate-bot
TRANSLATE_BOT_PASSWORD=CHANGE_ME_LONG_RANDOM

# Bridge appservice tokens — copied from each bridge's registration.yaml (as_token field).
# Used by translate-bot to invite itself into bridge portal rooms.
# Run: grep '^as_token:' bridges/<bridge>/registration.yaml
BRIDGE_TOKEN_WHATSAPP=
BRIDGE_TOKEN_TELEGRAM=
BRIDGE_TOKEN_SIGNAL=
BRIDGE_TOKEN_DISCORD=
BRIDGE_TOKEN_SLACK=
BRIDGE_TOKEN_GMESSAGES=
BRIDGE_TOKEN_TWITTER=
BRIDGE_TOKEN_GOOGLECHAT=
BRIDGE_TOKEN_LINKEDIN=
BRIDGE_TOKEN_META_FB=
BRIDGE_TOKEN_META_IG=

# Languages LibreTranslate will load models for.
# Fewer languages = faster startup + less RAM. en is always recommended.
LT_LANGUAGES=en,fr,es,de,pt,it,ar,zh,ja
